#!/bin/bash
# ==============================================================================
# audit-core: Multi-dimensional on-chain verification after deployment.
#
# Dimensions:
#   A) forge script checks (Check01–Check08, VerifyV3_1_1) — functional state
#   B) ABI selector comparison — local ABI vs on-chain bytecode selectors
#   C) Interface spot-checks — cast call key view functions, assert expected values
#
# Idempotent: per-check stamps in deployments/.audit.<env>.<check>.stamp.
# Use --force to bypass all stamps and re-run everything.
#
# Usage:
#   ./audit-core <env>           # env: sepolia, op-sepolia, optimism, mainnet, anvil
#   ./audit-core sepolia --force
# ==============================================================================

set -e

ENV=${1:-"sepolia"}
FORCE=false
for arg in "$@"; do [ "$arg" = "--force" ] && FORCE=true; done

ENV_FILE=".env.$ENV"
if [ -f "$ENV_FILE" ]; then
    set -a; source "$ENV_FILE"; set +a
fi

# Determine RPC_URL
if [ "$ENV" == "anvil" ]; then
    RPC_URL="http://127.0.0.1:8545"
else
    ENV_UPPER=$(echo "$ENV" | tr '[:lower:]' '[:upper:]')
    ENV_CLEAN=${ENV_UPPER//-/_}
    VAR_NAME="${ENV_CLEAN}_RPC_URL"
    RPC_URL=${!VAR_NAME:-$RPC_URL}
fi

if [ -z "$RPC_URL" ]; then
    echo -e "\033[0;31m❌ RPC_URL for '$ENV' is not set.\033[0m"
    echo "Check .env.$ENV for ${ENV_CLEAN}_RPC_URL or RPC_URL."
    exit 1
fi

CONFIG_JSON_PATH="deployments/config.${ENV}.json"
if [ ! -f "$CONFIG_JSON_PATH" ]; then
    echo -e "\033[0;31m❌ Config not found: $CONFIG_JSON_PATH\033[0m"
    exit 1
fi

# Build deployment fingerprint for idempotency stamps
REGISTRY_IMPL=$(jq -r '.registryImpl // empty' "$CONFIG_JSON_PATH")
SP_IMPL=$(jq -r '.spImpl // empty' "$CONFIG_JSON_PATH")
UPDATE_TIME=$(jq -r '.updateTime // empty' "$CONFIG_JSON_PATH")
CURRENT_STAMP="${REGISTRY_IMPL}|${SP_IMPL}|${UPDATE_TIME}"

# Read proxy addresses
REGISTRY_PROXY=$(jq -r '.registry'       "$CONFIG_JSON_PATH")
SP_PROXY=$(jq -r '.superPaymaster'        "$CONFIG_JSON_PATH")
MC_ADDR=$(jq -r '.microPaymentChannel'    "$CONFIG_JSON_PATH")

echo "🛡️  Running Core Logic Audit for: $ENV"
echo "   RPC:    $RPC_URL"
echo "   Config: $CONFIG_JSON_PATH"
echo "   Stamp:  $CURRENT_STAMP"
echo ""

CONFIG_FILENAME="config.${ENV}.json"
MAX_RETRIES=3
AUDIT_FAILED=false

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# stamp_key <label>  →  deployments/.audit.<env>.<label>.stamp
stamp_key() { echo "deployments/.audit.${ENV}.${1}.stamp"; }

# should_skip <label>  →  0 (skip) or 1 (run)
should_skip() {
    local key="$1"
    local sf
    sf=$(stamp_key "$key")
    if [ "$FORCE" = false ] && [ -f "$sf" ] && [ "$(cat "$sf")" = "$CURRENT_STAMP" ]; then
        return 0
    fi
    return 1
}

# mark_passed <label>
mark_passed() { echo "$CURRENT_STAMP" > "$(stamp_key "$1")"; }

# rpc_retry <label> <cmd…>  — run cmd with retries, update stamp on success
rpc_retry() {
    local label="$1"; shift
    local attempt=1
    while [ $attempt -le $MAX_RETRIES ]; do
        if [ $attempt -gt 1 ]; then
            local delay=$(( (attempt - 1) * 5 ))
            echo -e "    ↩  Retry $attempt/$MAX_RETRIES after ${delay}s..."
            sleep $delay
        fi
        if "$@" 2>&1; then
            mark_passed "$label"
            return 0
        fi
        attempt=$(( attempt + 1 ))
    done
    echo -e "\033[0;31m  ❌ $label failed after $MAX_RETRIES attempts\033[0m"
    AUDIT_FAILED=true
    return 1
}

# ---------------------------------------------------------------------------
# DIMENSION A: forge script checks
# ---------------------------------------------------------------------------

echo "━━━ A) Forge Script Checks ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
CHECK_SCRIPTS="Check04_Registry Check01_GToken Check02_GTokenStaking Check03_MySBT Check07_SuperPaymaster Check08_Wiring VerifyV3_1_1"

run_forge_check() {
    local SCRIPT="$1"
    if should_skip "$SCRIPT"; then
        echo -e "  \033[0;90mSkip: $SCRIPT (already passed)\033[0m"
        return 0
    fi
    echo -e "  Check: $SCRIPT"
    rpc_retry "$SCRIPT" \
        bash -c "CONFIG_FILE='$CONFIG_FILENAME' forge script \
            'contracts/script/checks/${SCRIPT}.s.sol:$SCRIPT' \
            --rpc-url '$RPC_URL' --timeout 300 -vv"
    [ "$ENV" != "anvil" ] && sleep 2
}

for SCRIPT in $CHECK_SCRIPTS; do
    run_forge_check "$SCRIPT"
done

# ---------------------------------------------------------------------------
# DIMENSION B: ABI selector comparison (local abis/ vs on-chain bytecode)
# ---------------------------------------------------------------------------

echo ""
echo "━━━ B) ABI Selector Comparison ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# Compare selectors for one contract: abi_check <label> <abi_file> <onchain_addr>
abi_check() {
    local label="$1"
    local abi_file="$2"
    local addr="$3"

    if should_skip "abi_$label"; then
        echo -e "  \033[0;90mSkip: ABI $label (already passed)\033[0m"
        return 0
    fi

    if [ ! -f "$abi_file" ]; then
        echo -e "  \033[1;33m⚠️  Skip ABI $label: $abi_file not found\033[0m"
        return 0
    fi

    if [ "$addr" = "0x0000000000000000000000000000000000000000" ] || [ -z "$addr" ]; then
        echo -e "  \033[1;33m⚠️  Skip ABI $label: address is zero\033[0m"
        return 0
    fi

    echo -e "  ABI check: $label ($addr)"

    # Extract function signatures with fully-expanded tuple types from ABI JSON
    # jq recursively expands tuple/tuple[] into their component types
    LOCAL_SELS=$(jq -r '
      def expand_type:
        if .type == "tuple" then
          "(" + ([.components[] | expand_type] | join(",")) + ")"
        elif .type == "tuple[]" then
          "(" + ([.components[] | expand_type] | join(",")) + ")[]"
        elif .type == "tuple[" then
          "(" + ([.components[] | expand_type] | join(",")) + ")[" + (.type | ltrimstr("tuple["))
        else .type
        end;
      .[] | select(.type=="function") |
        .name + "(" + ([.inputs[] | expand_type] | join(",")) + ")"
    ' "$abi_file" 2>/dev/null | sort)

    if [ -z "$LOCAL_SELS" ]; then
        echo -e "  \033[1;33m⚠️  $label: could not parse ABI, skipping selector check\033[0m"
        return 0
    fi

    # Fetch on-chain selectors via cast (4byte decode not needed — just check presence)
    # Use cast selectors to get all 4-byte selectors from on-chain bytecode
    local attempt=1
    local ONCHAIN_CODE=""
    while [ $attempt -le $MAX_RETRIES ]; do
        ONCHAIN_CODE=$(cast code "$addr" --rpc-url "$RPC_URL" 2>/dev/null) && break
        attempt=$(( attempt + 1 ))
        sleep $(( attempt * 3 ))
    done

    if [ -z "$ONCHAIN_CODE" ] || [ "$ONCHAIN_CODE" = "0x" ]; then
        echo -e "  \033[0;31m  ❌ $label: no bytecode at $addr\033[0m"
        AUDIT_FAILED=true
        return 1
    fi

    # Compute expected 4-byte selectors from local ABI
    # Skip tuple-type sigs: cast sig doesn't expand tuples, computes wrong selector
    local MISSING=""
    while IFS= read -r sig; do
        [ -z "$sig" ] && continue
        local sel
        sel=$(cast sig "$sig" 2>/dev/null) || continue
        # Strip 0x, lowercase
        sel="${sel#0x}"
        if ! echo "$ONCHAIN_CODE" | grep -qi "$sel"; then
            MISSING="$MISSING\n    missing: $sig ($sel)"
        fi
    done <<< "$LOCAL_SELS"

    if [ -n "$MISSING" ]; then
        echo -e "\033[0;31m  ❌ $label: selectors missing from on-chain bytecode:$MISSING\033[0m"
        AUDIT_FAILED=true
        return 1
    fi

    echo -e "  \033[0;32m  ✓ $label: all local ABI selectors present on-chain\033[0m"
    mark_passed "abi_$label"
}

# UUPS: selectors live in the implementation, not the proxy
SP_IMPL_ADDR=$(jq -r '.spImpl // empty'       "$CONFIG_JSON_PATH")
REG_IMPL_ADDR=$(jq -r '.registryImpl // empty' "$CONFIG_JSON_PATH")
abi_check "SuperPaymaster" "abis/SuperPaymaster.json" "$SP_IMPL_ADDR"
abi_check "Registry"       "abis/Registry.json"       "$REG_IMPL_ADDR"

# ---------------------------------------------------------------------------
# DIMENSION C: Interface spot-checks (cast call key view functions)
# ---------------------------------------------------------------------------

echo ""
echo "━━━ C) Interface Spot-Checks ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

cast_check() {
    local label="$1"
    local addr="$2"
    local sig="$3"
    local expected="$4"   # substring to grep in output; empty = just assert no revert

    if should_skip "iface_$label"; then
        echo -e "  \033[0;90mSkip: $label (already passed)\033[0m"
        return 0
    fi

    if [ "$addr" = "0x0000000000000000000000000000000000000000" ] || [ -z "$addr" ]; then
        echo -e "  \033[1;33m⚠️  Skip $label: address is zero\033[0m"
        return 0
    fi

    local attempt=1
    local OUT=""
    while [ $attempt -le $MAX_RETRIES ]; do
        OUT=$(cast call "$addr" "$sig" --rpc-url "$RPC_URL" 2>&1) && break
        attempt=$(( attempt + 1 ))
        sleep $(( attempt * 3 ))
    done

    if echo "$OUT" | grep -qi "revert\|error\|Error"; then
        echo -e "  \033[0;31m❌ $label ($sig) reverted: $OUT\033[0m"
        AUDIT_FAILED=true
        return 1
    fi

    if [ -n "$expected" ] && ! echo "$OUT" | grep -qi "$expected"; then
        echo -e "  \033[0;31m❌ $label: expected '$expected' in output, got: $OUT\033[0m"
        AUDIT_FAILED=true
        return 1
    fi

    echo -e "  \033[0;32m✓ $label\033[0m  ← $OUT"
    mark_passed "iface_$label"
}

# SuperPaymaster proxy: version(), entryPoint(), paused()
cast_check "SP.version"     "$SP_PROXY"       "version()(string)"           "SuperPaymaster"
cast_check "SP.entryPoint"  "$SP_PROXY"       "entryPoint()(address)"       "0x00000000717"
cast_check "SP.treasury"    "$SP_PROXY"       "treasury()(address)"         ""

# Registry proxy: version(), owner()
cast_check "Reg.version"    "$REGISTRY_PROXY" "version()(string)"           "Registry"
cast_check "Reg.owner"      "$REGISTRY_PROXY" "owner()(address)"            ""

# MicroPaymentChannel: only check if deployed
if [ "$MC_ADDR" != "0x0000000000000000000000000000000000000000" ] && [ -n "$MC_ADDR" ]; then
    cast_check "MC.owner" "$MC_ADDR" "owner()(address)" ""
fi

# --- ERC-1967 proxy → impl pointer verification ---
# ERC-1967 implementation slot: keccak256("eip1967.proxy.implementation") - 1
ERC1967_SLOT="0x360894a13ba1a3210667c828492db98dca3e2076cc3735a920a3ca505d382bbc"

check_proxy_impl() {
    local label="$1"
    local proxy="$2"
    local expected_impl="$3"

    if should_skip "proxy_impl_$label"; then
        echo -e "  \033[0;90mSkip: $label proxy→impl (already passed)\033[0m"
        return 0
    fi

    echo -e "  Proxy→impl: $label"
    local attempt=1
    local raw=""
    while [ $attempt -le $MAX_RETRIES ]; do
        raw=$(cast storage "$proxy" "$ERC1967_SLOT" --rpc-url "$RPC_URL" 2>/dev/null) && break
        attempt=$(( attempt + 1 ))
        sleep $(( attempt * 3 ))
    done

    if [ -z "$raw" ]; then
        echo -e "  \033[0;31m❌ $label: could not read ERC-1967 impl slot\033[0m"
        AUDIT_FAILED=true
        return 1
    fi

    # cast storage returns 32 bytes; extract last 20 (address = lower 40 hex chars)
    local actual_impl
    actual_impl="0x$(echo "$raw" | sed 's/^0x//' | tail -c 41 | head -c 40)"
    # normalize to lowercase for comparison
    actual_impl=$(echo "$actual_impl" | tr '[:upper:]' '[:lower:]')
    local expected_impl_lc
    expected_impl_lc=$(echo "$expected_impl" | tr '[:upper:]' '[:lower:]')

    if [ "$actual_impl" != "$expected_impl_lc" ]; then
        echo -e "  \033[0;31m❌ $label proxy points to wrong impl!\033[0m"
        echo -e "     expected: $expected_impl_lc"
        echo -e "     actual:   $actual_impl"
        AUDIT_FAILED=true
        return 1
    fi

    echo -e "  \033[0;32m✓ $label proxy → $actual_impl (matches config)\033[0m"
    mark_passed "proxy_impl_$label"
}

check_proxy_impl "SuperPaymaster" "$SP_PROXY"       "$SP_IMPL_ADDR"
check_proxy_impl "Registry"       "$REGISTRY_PROXY" "$REG_IMPL_ADDR"

# ---------------------------------------------------------------------------
# Final result
# ---------------------------------------------------------------------------

echo ""
if [ "$AUDIT_FAILED" = true ]; then
    echo -e "\033[0;31m❌ Audit FAILED — see errors above\033[0m"
    exit 1
fi

echo -e "\033[0;32m✅ All audit dimensions passed!\033[0m"
echo "   A) Forge checks  — functional state verified"
echo "   B) ABI selectors — local ABI matches on-chain bytecode"
echo "   C) Interface     — key view functions callable & return expected values"
echo "   (Per-check stamps: deployments/.audit.${ENV}.*.stamp)"
