#!/bin/bash
# ==============================================================================
# Phase 2: Test Account and Demo Preparation
# ==============================================================================

set -e # Fail fast

ENV=${1:-"anvil"}
ENV_FILE=".env.$ENV"

if [ -f "$ENV_FILE" ]; then
    set -a; source "$ENV_FILE"; set +a
fi

# Determine RPC
if [ "$ENV" == "anvil" ]; then
    RPC_URL="http://127.0.0.1:8545"
else
    ENV_UPPER=$(echo $ENV | tr '[:lower:]' '[:upper:]')
    ENV_CLEAN=${ENV_UPPER//-/_}
    VAR_NAME="${ENV_CLEAN}_RPC_URL"
    RPC_URL=${!VAR_NAME:-$RPC_URL}
fi

if [ -z "$RPC_URL" ]; then
    echo -e "\033[0;31m❌ Error: RPC_URL for environment '$ENV' is not defined.\033[0m"
    exit 1
fi

export CONFIG_FILE="config.$ENV.json"
export ENV="$ENV"

# Determine Signer (same logic as deploy-core)
FORGE_FLAGS="--rpc-url $RPC_URL --broadcast --slow --timeout 300 -vv"
if [ -n "$DEPLOYER_ACCOUNT" ]; then
    FORGE_FLAGS="$FORGE_FLAGS --account $DEPLOYER_ACCOUNT"
elif [ -n "$PRIVATE_KEY" ]; then
    FORGE_FLAGS="$FORGE_FLAGS --private-key $PRIVATE_KEY"
else
    if [ "$ENV" == "anvil" ]; then
        FORGE_FLAGS="$FORGE_FLAGS --private-key 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"
    else
        echo "❌ Error: No DEPLOYER_ACCOUNT or PRIVATE_KEY defined"
        exit 1
    fi
fi

echo "🧪 Starting Phase 2: Test Account Preparation ($ENV)"

forge script "contracts/script/v3/TestAccountPrepare.s.sol:TestAccountPrepare" $FORGE_FLAGS

echo -e "\n🛡️ Verifying Test Accounts..."
forge script "contracts/script/checks/Check09_TestAccounts.s.sol:Check09_TestAccounts" \
    --rpc-url "$RPC_URL" --timeout 300 -vv

echo -e "\n\033[0;32m✅ Test Environment is Prepared & Verified!\033[0m"
