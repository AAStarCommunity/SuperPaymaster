#!/bin/bash
# ==============================================================================
# Phase 1: Core Infrastructure Deployment
# ==============================================================================

set -e # Fail fast on any command failure

ENV=${1:-"anvil"}
ENV_FILE=".env.$ENV"

if [ -f "$ENV_FILE" ]; then
    set -a; source "$ENV_FILE"; set +a
fi

# Determine RPC
if [ "$ENV" == "anvil" ]; then
    RPC_URL="http://127.0.0.1:8545"
else
    ENV_UPPER=$(echo $ENV | tr '[:lower:]' '[:upper:]')
    ENV_CLEAN=${ENV_UPPER//-/_}
    VAR_NAME="${ENV_CLEAN}_RPC_URL"
    RPC_URL=${!VAR_NAME:-$RPC_URL}
fi

if [ -z "$RPC_URL" ]; then
    echo -e "\033[0;31m❌ Error: RPC_URL for environment '$ENV' is not defined.\033[0m"
    echo "Check if .env.$ENV exists and contains ${ENV_CLEAN}_RPC_URL"
    exit 1
fi

# Smart Hash Check
# Cover Solidity sources AND the build/deploy toolchain files so that changes to
# foundry.toml (optimizer, profile, remappings), remappings.txt, or deploy-core
# itself will also trigger a fresh deploy rather than being silently skipped.
CURRENT_HASH=$(
  { find contracts/src -name "*.sol" -not -path "*/mocks/*" -type f -exec shasum -a 256 {} +; \
    shasum -a 256 foundry.toml remappings.txt deploy-core 2>/dev/null; } \
  | sort | shasum -a 256 | awk '{print $1}')
CONFIG_FILE_PATH="deployments/config.$ENV.json"

FORCE_DEPLOY=false
FRESH_DEPLOY=false
if [[ "$*" == *"--force"* ]];        then FORCE_DEPLOY=true; fi
if [[ "$*" == *"--fresh-deploy"* ]]; then FRESH_DEPLOY=true; fi

# Warn loudly if --fresh-deploy is used on a live network (destructive — creates new proxies)
if [ "$FRESH_DEPLOY" = true ] && [ "$ENV" != "anvil" ]; then
    echo -e "\033[0;31m⚠️  WARNING: --fresh-deploy will deploy NEW UUPS proxies and LOSE all on-chain state\033[0m"
    echo -e "\033[0;31m   (registered communities, staked GToken, SBT records, etc.)\033[0m"
    echo -e "\033[0;31m   Only use this for brand-new network deployments!\033[0m"
    read -p "   Type 'yes' to confirm fresh deployment on $ENV: " CONFIRM
    if [ "$CONFIRM" != "yes" ]; then
        echo "Aborted."
        exit 1
    fi
fi

SHOULD_RUN_DEPLOY=false
if [ "$ENV" != "anvil" ] && [ -f "$CONFIG_FILE_PATH" ] && [ "$FORCE_DEPLOY" = false ] && [ "$FRESH_DEPLOY" = false ]; then
    STORED_HASH=$(jq -r '.srcHash // ""' "$CONFIG_FILE_PATH")
    if [ "$CURRENT_HASH" == "$STORED_HASH" ]; then
        echo "✅ Code unchanged ($CURRENT_HASH). Skipping Core Deployment."
        SHOULD_RUN_DEPLOY=false
    else
        echo "🔄 Code changed. Old: $STORED_HASH -> New: $CURRENT_HASH"
        SHOULD_RUN_DEPLOY=true
    fi
else
    # Anvil, no config file, --force, or --fresh-deploy
    SHOULD_RUN_DEPLOY=true
fi

export CONFIG_FILE="config.$ENV.json"
# SRC_HASH is intentionally NOT exported here.  The forge deploy scripts write
# srcHash via vm.envOr("SRC_HASH", ""), so the config will contain an empty hash
# after deployment.  deploy-core writes the real hash into the config ONLY after
# audit-core passes (see "Commit srcHash" block below).  This prevents a failed
# audit from leaving a valid-looking srcHash in config that would cause the next
# run to skip both the deploy and the audit.
export DEPLOY_TIME=$(date "+%Y-%m-%d %H:%M:%S")
export ENV="$ENV"

# ─── Routing: Anvil → DeployAnvil, live fresh → DeployLive, live upgrade → UpgradeLive ───
# From v5.3.3-beta onwards, ALL SuperPaymaster/Registry changes on live networks
# MUST go through UpgradeLive (UUPS) to preserve proxy addresses and on-chain state.
# Use --fresh-deploy only for brand-new network deployments.
if [ "$ENV" == "anvil" ]; then
    SCRIPT_NAME="DeployAnvil"
elif [ "$FRESH_DEPLOY" = true ] || ! jq -e '.registry != null and .registry != "0x0000000000000000000000000000000000000000"' "$CONFIG_FILE_PATH" > /dev/null 2>&1; then
    # Fresh deploy: no config yet, or --fresh-deploy flag
    SCRIPT_NAME="DeployLive"
    echo "🆕 Mode: Fresh Deploy (DeployLive)"
else
    # Existing proxies found → UUPS upgrade (preserves state)
    SCRIPT_NAME="UpgradeLive"
    echo "🔄 Mode: UUPS Upgrade (UpgradeLive) — proxy addresses preserved"
fi

# Prepare Forge flags
FORGE_FLAGS="--rpc-url $RPC_URL --broadcast --slow -vv"
if [ "$ENV" == "anvil" ]; then
    # Bypass EIP-170 size-limit interactive prompt on Anvil (size limits are advisory,
    # not enforced by Anvil's EVM). Without this flag, forge 1.4+ will request terminal
    # confirmation when a contract exceeds 24576 bytes, causing CI/non-TTY failures.
    FORGE_FLAGS="$FORGE_FLAGS --disable-code-size-limit"
else
    # --non-interactive: forge 1.4+ prompts for broadcast confirmation via /dev/tty even
    # with --broadcast, which blocks non-TTY (CI/background) runs indefinitely.
    FORGE_FLAGS="$FORGE_FLAGS --timeout 300 --non-interactive"
fi

# Determine Signer
if [ -n "$DEPLOYER_ACCOUNT" ]; then
    echo "🔐 Using Foundry Keystore Account: $DEPLOYER_ACCOUNT"
    
    # Check if DEPLOYER_ADDRESS is already configured to skip password prompt
    if [ -n "$DEPLOYER_ADDRESS" ]; then
        echo "   ✅ Using configured address: $DEPLOYER_ADDRESS"
    else
        echo "   🔍 Resolving address from keystore (Password Required)..."
        DEPLOYER_ADDR=$(cast wallet address --account $DEPLOYER_ACCOUNT)
        echo "   📍 Resolved Address: $DEPLOYER_ADDR"
        export DEPLOYER_ADDRESS=$DEPLOYER_ADDR
    fi
    
    # When using --account, we don't need --sender if the account is the sender
    FORGE_FLAGS="$FORGE_FLAGS --account $DEPLOYER_ACCOUNT"
elif [ -n "$PRIVATE_KEY" ]; then
     echo "⚠️  Using Plaintext Private Key (Not Recommended)"
     FORGE_FLAGS="$FORGE_FLAGS --private-key $PRIVATE_KEY"
else
     # For Anvil, we can use the default test account if needed, or fail for live nets
     if [ "$ENV" != "anvil" ]; then
        echo "❌ Error: No DEPLOYER_ACCOUNT or PRIVATE_KEY defined in .env.$ENV"
        exit 1
     else
        # Anvil default (0xf39... id 0)
        echo "🔧 Using Anvil Default Account"
        FORGE_FLAGS="$FORGE_FLAGS --private-key 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"
        # Export the corresponding address so VerifyV3_1_1 can resolve DEPLOYER_ADDRESS
        export DEPLOYER_ADDRESS="0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266"
     fi
fi

if [ "$SHOULD_RUN_DEPLOY" = true ]; then
    echo "🚀 Starting Phase 1: Core Infrastructure Deployment ($ENV)"
    forge script "contracts/script/v3/${SCRIPT_NAME}.s.sol:$SCRIPT_NAME" $FORGE_FLAGS

    # Sync ABI JSONs from compiled artifacts (keeps abis/ in sync with deployed bytecode)
    echo "  📄 Syncing ABI JSONs from out/..."
    for contract in SuperPaymaster Registry xPNTsToken xPNTsFactory GToken GTokenStaking MySBT MicroPaymentChannel X402Facilitator PolicyRegistry TimelockController; do
        artifact=$(find out -name "${contract}.json" -not -path "*test*" 2>/dev/null | head -1)
        if [ -n "$artifact" ]; then
            jq '.abi' "$artifact" > "abis/${contract}.json" 2>/dev/null && echo "    ✓ $contract" || true
        fi
    done
fi

# --- PHASE 2: Core Logic Audit (Self-Verification) ---
# Delegate to audit-core (per-check idempotency + retry + ABI/interface checks).
# --force because we just deployed: stamps from a previous run are now stale.
echo ""
if [ -x "./audit-core" ]; then
    ./audit-core "$ENV"
else
    echo -e "\033[0;31m❌ audit-core not found or not executable. Run: chmod +x audit-core\033[0m"
    exit 1
fi

echo -e "\n\033[0;32m✅ Core Infrastructure is Deployed & Audited!\033[0m"

# --- Commit srcHash (only after all audit checks passed) ---
# The forge deploy scripts wrote srcHash="" to config (SRC_HASH was not exported).
# Now that audit-core has returned 0 we can safely record the real hash so that
# the next deploy-core invocation can skip the deploy when sources are unchanged.
# If audit-core had failed (exit 1), set -e would have aborted before this point,
# leaving srcHash="" in config and forcing a full redeploy+reaudit on the next run.
if [ -f "$CONFIG_FILE_PATH" ]; then
    echo "  📝 Committing srcHash to config (${CURRENT_HASH})..."
    jq --arg h "$CURRENT_HASH" '.srcHash = $h' "$CONFIG_FILE_PATH" \
        > "${CONFIG_FILE_PATH}.tmp" && mv "${CONFIG_FILE_PATH}.tmp" "$CONFIG_FILE_PATH"
    echo "  ✅ srcHash committed."
fi

# --- PHASE 2.5: Prepare Test Accounts (testnet only, not mainnet/optimism) ---
# After a successful deploy, idempotently set up the Mycelium/Anni demo operator.
# Skipped on mainnet and optimism (real money; manual operator onboarding required).
# prepare-test is itself idempotent — each step checks before acting.
if [ "$SHOULD_RUN_DEPLOY" = true ]; then
    case "$ENV" in
        sepolia|op-sepolia|anvil)
            echo ""
            echo "━━━ Phase 2.5) Prepare Test Accounts ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            if [ -x "./prepare-test" ]; then
                ./prepare-test "$ENV" || echo -e "\033[1;33m⚠️  prepare-test failed. Re-run './prepare-test $ENV' manually.\033[0m"
            else
                echo -e "\033[1;33m⚠️  prepare-test not executable; skipping test account setup.\033[0m"
            fi
            ;;
        mainnet|optimism|op-mainnet)
            echo -e "\n\033[0;33mℹ️  Skipping prepare-test on $ENV (mainnet — manual operator onboarding required)\033[0m"
            echo -e "\033[0;33m   Run: forge script contracts/script/v3/InitializeAAStar.s.sol --account \$DEPLOYER_ACCOUNT --broadcast\033[0m"
            echo -e "\033[0;33m        forge script contracts/script/v3/InitializeMycelium.s.sol --account \$ANNI_ACCOUNT --broadcast\033[0m"
            ;;
    esac
fi

# --- PHASE 3: Etherscan Verification (live networks only) ---
# Skip for anvil; for sepolia / op-* / mainnet, submit every freshly-deployed
# contract to Etherscan so external tools (SDK, audit, block explorer users)
# can see the ABI immediately. Idempotent: already-verified contracts return
# success fast. Failure is non-fatal — operator can re-run `./verify-all.sh
# --env $ENV` later. See memory: 部署后必须 verify.
if [ "$ENV" != "anvil" ] && [ "$SHOULD_RUN_DEPLOY" = true ]; then
    echo -e "\n🔍 Starting Etherscan verification (this can take a few minutes)..."
    if [ -x "./verify-all.sh" ]; then
        ./verify-all.sh --env "$ENV" || echo -e "\033[1;33m⚠️  Some contracts failed to verify. Re-run './verify-all.sh --env $ENV' manually.\033[0m"
    else
        echo -e "\033[1;33m⚠️  verify-all.sh not executable; skipping Etherscan verification.\033[0m"
    fi
fi

echo -e "\n\033[0;32m✅ deploy-core finished for env=$ENV\033[0m"
